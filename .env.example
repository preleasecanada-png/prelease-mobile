# ============================================
# Prelease Canada — Mobile Environment Variables
# ============================================

# Backend API URL (AWS API Gateway endpoint)
API_BASE_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/api

# Image base URL (S3 bucket or API storage URL)
IMAGE_BASE_URL=https://your-s3-bucket.s3.us-east-1.amazonaws.com

# Pusher (real-time chat)
PUSHER_APP_KEY=your-pusher-app-key
PUSHER_APP_CLUSTER=us2
